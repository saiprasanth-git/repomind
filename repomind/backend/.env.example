# ── Copy this file to .env and fill in your values ──────────────────────────
# Never commit .env to git — it contains secrets.

# ── Required ─────────────────────────────────────────────────────────────────

# Google AI Studio API Key — get it at: https://aistudio.google.com/app/apikey
# Used for: Gemini 1.5 Pro (long-context engine) + text-embedding-004 (embeddings)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key — get it at: https://platform.openai.com/api-keys
# Used for: GPT-4o (comparison baseline in the research experiment)
OPENAI_API_KEY=your_openai_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────

# GitHub Personal Access Token — https://github.com/settings/tokens
# Without this: 60 API requests/hour (enough for demos)
# With this:    5,000 API requests/hour (needed for heavy use)
# Required for: indexing private repos
GITHUB_TOKEN=

# PostgreSQL connection string
# Default works with docker-compose setup
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/repomind
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/repomind

# App settings
DEBUG=true
ENVIRONMENT=development
